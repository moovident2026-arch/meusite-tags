generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String @id @default(cuid())
  name      String
  email     String @unique
  password  String
  whatsapp  String
  birthdate String
  city      String
  tags      Tag[]
}

model Tag {
  id        String @id @default(cuid())
  tag       String @unique
  object    String
  createdAt DateTime @default(now())

  userId String
  user   User @relation(fields: [userId], references: [id])
}